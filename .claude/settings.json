{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git checkout *)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(vercel *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Grep(*)",
      "Glob(*)"
    ],
    "ask": [
      "Bash(pnpm db:migrate*)",
      "Bash(pnpm db:push*)",
      "Bash(pnpm db:reset*)",
      "Bash(vercel env*)",
      "Bash(vercel --prod*)",
      "Bash(gh pr merge*)",
      "Bash(stripe *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *anthropic*)",
      "Bash(psql*DROP*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-pii.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck --incremental --silent || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/context-reminder.js"
          }
        ]
      }
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
