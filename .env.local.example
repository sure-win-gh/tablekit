# -----------------------------------------------------------------------------
# TableKit — local env
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. Never commit
# `.env.local`. Every value here is a placeholder — replace before use.
#
# Precedence at runtime (Next.js): .env.local > .env.development > .env.
# Secrets belong in `.env.local` only; `.env` is reserved for non-secret
# defaults if we ever need them.
# -----------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------

# Where the dashboard is served (used for CORS, absolute URLs in email).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Where the embeddable widget is served.
NEXT_PUBLIC_WIDGET_URL="http://localhost:3000"

# Signing secret for session cookies, CSRF tokens, invite JWTs.
# `openssl rand -base64 48` to generate. Rotate quarterly — see security.md.
SESSION_SIGNING_SECRET="changeme_generate_48_random_bytes_base64"

# Flip the /dashboard + /admin Content-Security-Policy from Report-Only to
# enforcing. Leave empty/false during the report-only soak; set to "true" in
# production once /api/csp-report shows no violations. See security.md.
CSP_DASHBOARD_ENFORCE=""

# --- Supabase ----------------------------------------------------------------

# Your Supabase project URL and anon (public) key — safe to bundle.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# service_role key — BYPASSES RLS. Only used by lib/server/admin/*.
# Rotate quarterly (security.md §Secret rotation schedule).
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Postgres connection string used by Drizzle (migrations + the app's
# `withUser` RLS wrapper) and by scripts/check-rls.ts.
#
# From Supabase dashboard → Project Settings → Database → Connection
# string → *Session pooler* tab (NOT Direct, NOT Transaction pooler —
# the transaction-per-request pattern needs session-mode pooling to
# behave correctly).
#
# Shape: postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# --- Multi-region (docs/specs/multi-region.md) --------------------------------
#
# Region-keyed database URLs (Phase 1 alias pattern, lib/regions/config.ts):
#   - DATABASE_URL_EU falls back to DATABASE_URL, so single-region setups
#     (local dev included) need not set it.
#   - DATABASE_URL_US is the Phase-4 US Supabase project (session pooler
#     URL, same shape as above). Unset = the US region FAILS CLOSED —
#     there is deliberately no fallback to the EU database.
#   - Values containing "YOUR_" are treated as unset.
# DATABASE_URL_EU=""
# DATABASE_URL_US=""

# US region master switch. The US signup/data path stays dark unless this
# is exactly "true" AND DATABASE_URL_US is set. Gated on the external
# launch gates (US entity + Stripe account, state sales-tax registrations)
# — see docs/specs/multi-region.md §Launch gates.
REGION_US_ENABLED="false"

# --- Stripe ------------------------------------------------------------------
#
# These three keys come from Stripe Dashboard → Developers (test mode).
# Values containing "YOUR_" are treated as unset by lib/stripe/client.ts
# so you can keep them as placeholders until you're ready to wire
# Stripe up — integration + e2e tests that need a real key will skip.
#
# To exercise the webhook locally:
#   $ stripe login             # once per machine
#   $ stripe listen --forward-to localhost:3000/api/stripe/webhook
# The listen command prints the whsec_ value for STRIPE_WEBHOOK_SECRET.

# Test-mode secret key (sk_test_...). Never commit live keys.
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"

# Test-mode publishable key — safe to bundle.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"

# Webhook signing secret. Rotate quarterly (payments.md).
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"

# --- Stripe billing (platform-account SaaS subscriptions) --------------------
#
# SEPARATE from Connect/deposits above — here Tablekit is the merchant
# charging the venue its monthly plan. Create the Products/Prices in the
# Stripe dashboard (test mode) and paste the price_... ids here.
#   STRIPE_PRICE_CORE   — recurring £19/mo  (plan = core)
#   STRIPE_PRICE_PLUS   — recurring £39/mo  (plan = plus)
#   STRIPE_PRICE_USAGE  — metered price tied to the usage Meter (optional
#                         until the meter is set up; see docs/playbooks/deploy.md).
# Values containing "YOUR_" / not starting with price_ are treated as unset.
STRIPE_PRICE_CORE="price_YOUR_CORE_PRICE_ID"
STRIPE_PRICE_PLUS="price_YOUR_PLUS_PRICE_ID"
STRIPE_PRICE_USAGE="price_YOUR_USAGE_PRICE_ID"
# The Billing Meter's event_name (sum-aggregated, £0.01/unit → report pence).
# Used by /api/cron/billing-meter-sync to report transactional usage.
STRIPE_METER_USAGE_EVENT_NAME="YOUR_METER_EVENT_NAME"

# --- Vercel Cron -------------------------------------------------------------

# Shared secret sent in the Authorization header by Vercel Cron. Any
# string is fine; must match what you set in the Vercel project env.
# See vercel.json for the current schedule + routes.
CRON_SECRET="YOUR_CRON_SECRET"

# --- Resend (email) ----------------------------------------------------------

RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
RESEND_FROM_EMAIL="TableKit <no-reply@example.com>"
# Svix signature secret for outbound-event webhooks (bounces, complaints, delivered).
RESEND_WEBHOOK_SECRET="whsec_YOUR_RESEND_WEBHOOK_SECRET"
# Svix signature secret for the INBOUND email webhook (AI enquiry handler,
# Plus tier). Configured in Resend → Inbound → Webhook for the
# `enquiries.tablekit.uk` MX target. Distinct from RESEND_WEBHOOK_SECRET
# because the two webhooks are separate Resend resources with their own keys.
RESEND_INBOUND_SECRET="whsec_YOUR_RESEND_INBOUND_SECRET"

# --- Twilio (SMS) ------------------------------------------------------------

TWILIO_ACCOUNT_SID="ACYOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_FROM_NUMBER="+441234567890"

# --- Twilio (WhatsApp) -------------------------------------------------------
# WhatsApp rides the same Twilio account as SMS. Set the WhatsApp sender
# (sandbox number for dev, an approved WhatsApp Business number in prod).
# Bare E.164 is fine — the code adds the `whatsapp:` prefix.
# NOTE (gdpr.md): WhatsApp routes guest numbers + content through Meta's
# global infrastructure — a deliberate non-EU sub-processor exception.
TWILIO_WHATSAPP_FROM="+14155238886"
# Approved Meta/Twilio Content template SIDs (HX…) for business-initiated
# sends outside the 24h session window. Leave unset in dev to fall back
# to freeform body (valid only in the sandbox / open session).
TWILIO_WA_TEMPLATE_BOOKING_CONFIRMATION="HXYOUR_APPROVED_TEMPLATE_SID"
TWILIO_WA_TEMPLATE_BOOKING_REMINDER_24H="HXYOUR_APPROVED_TEMPLATE_SID"
TWILIO_WA_TEMPLATE_BOOKING_REMINDER_2H="HXYOUR_APPROVED_TEMPLATE_SID"

# --- AWS Bedrock (AI enquiry handler — Plus tier) ----------------------------
# Claude Haiku 4.5 served via Bedrock in eu-west-1 (Ireland). Using
# Bedrock + EU residency rather than the direct Anthropic API keeps
# guest PII inside the EU sub-processor list — see gdpr.md §Current
# sub-processors and lib/llm/bedrock.ts for the full rationale.
#
# Recommended path: Bedrock long-term API key (no AWS IAM setup).
# Bedrock Console → API keys → Create long-term key. The Bedrock
# SDK reads this from `AWS_BEARER_TOKEN_BEDROCK` automatically.
#
# Alternative: standard AWS IAM credentials via the credential
# provider chain (env vars `AWS_ACCESS_KEY_ID` / `AWS_SECRET_ACCESS_KEY`,
# IAM role on EC2/ECS, `~/.aws/credentials`, etc.). Pick one — don't
# mix.
#
# `AWS_REGION` is what the Bedrock SDK reads if you don't pin a
# region in code. We DO pin to `eu-west-1` in lib/llm/bedrock.ts
# (load-bearing for residency), so AWS_REGION is informational here.

AWS_BEARER_TOKEN_BEDROCK="YOUR_AWS_BEARER_TOKEN_BEDROCK"
AWS_REGION="eu-west-1"

# --- Google Business Profile (OAuth) ----------------------------------------
# Per-venue OAuth connection for pulling reviews + posting replies.
# Console: console.cloud.google.com → APIs & Services → Credentials.
# OAuth consent screen needs the `business.manage` scope (sensitive
# scope — Google verification required before public launch). The
# redirect URI must match NEXT_PUBLIC_APP_URL + /api/oauth/google/callback
# exactly. Leave the placeholder string in to disable the integration —
# the settings page renders a "Coming soon" button.
#
# Full setup (incl. the Business Profile API access-approval gotcha):
# docs/playbooks/google-reviews-setup.md

GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
# Optional — space/comma-separated; defaults to the business.manage scope.
# GOOGLE_OAUTH_SCOPES="https://www.googleapis.com/auth/business.manage"

# --- Google Places API (outreach pre-populated accounts) ---------------------
# Server-side API key used by lib/google/places.ts to look up a
# prospect's venue (name, address, hours, website) from the internal
# /admin/outreach tool. Console: APIs & Services → Credentials →
# Create credentials → API key. Restrict the key to "Places API (New)"
# and the production server's IP — never bundle this into a client.
# ~£0.005 per text-search; ~£0.014 per place-details with the field
# mask we use. Empty = outreach UI shows a "not configured" notice.

GOOGLE_PLACES_API_KEY=""

# --- Sentry ------------------------------------------------------------------
#
# Use the EU-region ingest host (…ingest.de.sentry.io) so error data
# stays in-region per docs/playbooks/gdpr.md. With no DSN set, Sentry
# is inert — local dev and CI run without it. NEXT_PUBLIC_SENTRY_DSN is
# the same DSN exposed to the browser bundle (safe: a DSN only permits
# sending events, not reading them).

SENTRY_DSN="https://YOUR_SENTRY_DSN@oXXXXX.ingest.de.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_SENTRY_DSN@oXXXXX.ingest.de.sentry.io/0"
SENTRY_ORG="YOUR_SENTRY_ORG"
SENTRY_PROJECT="tablekit"
# Source-map upload (CI / Vercel build only). No token = no upload.
SENTRY_AUTH_TOKEN=""

# --- Slack alerting ----------------------------------------------------------
#
# Incoming Webhook URL for production alerts (health-check failure,
# critical errors). Empty = alerting no-ops. Create one at
# api.slack.com/apps → Incoming Webhooks.

SLACK_ALERT_WEBHOOK_URL=""

# --- Upstash Redis (rate limiting) -------------------------------------------

UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REST_TOKEN"

# --- hCaptcha (widget anti-abuse) --------------------------------------------

NEXT_PUBLIC_HCAPTCHA_SITEKEY="YOUR_HCAPTCHA_SITEKEY"
HCAPTCHA_SECRET="YOUR_HCAPTCHA_SECRET"

# --- Reserve with Google -----------------------------------------------------

# HMAC-SHA256 shared secret for RWG webhook verification (security.md).
RWG_SHARED_SECRET="changeme_reserve_with_google_shared_secret"

# --- Encryption --------------------------------------------------------------

# Envelope-encryption master key. Wraps each organisation's per-row
# data-encryption key (DEK), which in turn encrypts PII columns (see
# docs/playbooks/gdpr.md §Encryption). Also used as the pepper for
# `hashForLookup` so lookup hashes survive without exposing plaintext.
#
# Shape: 32 raw bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
#
# Rotation: today a rotation invalidates every wrapped DEK and every
# lookup hash in the DB. Treat it as a data-migration event. Production
# hardening moves this to Supabase Vault / KMS; the API surface in
# lib/security/crypto.ts stays identical.
TABLEKIT_MASTER_KEY="changeme_openssl_rand_base64_32"

# --- Internal admin dashboard ------------------------------------------------

# Email allowlist for the /admin (Tablekit-staff) dashboard. Comma- or
# whitespace-separated. Empty = no one can access /admin (fail-closed).
# Both proxy.ts and lib/server/admin/auth.ts re-parse this on every
# request so a redeploy picks up changes without a process restart.
ADMIN_EMAILS=""

# --- Kill switches (see incident.md) -----------------------------------------

WIDGET_DISABLED="false"
BOOKINGS_READ_ONLY="false"
PAYMENTS_DISABLED="false"
RWG_DISABLED="false"
SMS_DISABLED="false"
EMAIL_DISABLED="false"

# --- POS integrations (Plus tier) --------------------------------------------

# Square (Connect OAuth + webhooks). Read-only scopes only — see
# lib/pos/square/oauth.ts. The signature key + the EXACT registered webhook
# URL are part of Square's HMAC, so SQUARE_WEBHOOK_URL must match byte-for-byte
# what's configured in the Square dashboard.
SQUARE_CLIENT_ID="YOUR_SQUARE_CLIENT_ID"
SQUARE_CLIENT_SECRET="YOUR_SQUARE_CLIENT_SECRET"
SQUARE_WEBHOOK_SIGNATURE_KEY="YOUR_SQUARE_WEBHOOK_SIGNATURE_KEY"
SQUARE_WEBHOOK_URL="https://api.tablekit.uk/api/webhooks/pos/square"
# SQUARE_API_BASE="https://connect.squareup.com"  # default; override for sandbox

# Lightspeed Restaurant (K-Series) — PARTNER-GATED. Disabled unless
# LIGHTSPEED_PARTNER_ENABLED=true AND credentials are set (go-live: partner
# approval required first). Webhook secret is per-connection (stored encrypted),
# not an env var.
LIGHTSPEED_PARTNER_ENABLED="false"
LIGHTSPEED_CLIENT_ID="YOUR_LIGHTSPEED_CLIENT_ID"
LIGHTSPEED_CLIENT_SECRET="YOUR_LIGHTSPEED_CLIENT_SECRET"
# LIGHTSPEED_API_BASE="https://api.lightspeedapp.com"  # default

# Generic POS path (signed webhook + CSV) has no env: each connection carries
# its own webhook secret (stored encrypted in pos_connections).

# --- Feature flags (binary, per deploy.md) -----------------------------------

# Per-env toggles. Gradual per-org rollouts use the feature_flags table.
FEATURE_WAITLIST="false"
