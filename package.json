{
  "name": "tablekit",
  "version": "0.1.0",
  "private": true,
  "description": "UK table booking SaaS for independent hospitality.",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:backfill-phone-hash": "tsx --conditions=react-server scripts/backfill-phone-hash.ts",
    "check:rls": "tsx scripts/check-rls.ts",
    "check:migrations": "tsx scripts/check-migration-safety.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "0.29.1",
    "@anthropic-ai/sdk": "0.92.0",
    "@calcom/embed-react": "1.5.3",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.7",
    "@sentry/nextjs": "10.53.1",
    "@stripe/react-stripe-js": "6.2.0",
    "@stripe/stripe-js": "9.3.1",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.0",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.11.0",
    "next": "16.2.6",
    "papaparse": "5",
    "postcss": "8.5.16",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.1",
    "resend": "6.12.2",
    "sanitize-html": "2.17.5",
    "server-only": "0.0.1",
    "stripe": "22.0.2",
    "twilio": "6.0.0",
    "zod": "4.3.6",
    "zod-openapi": "5.4.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.19.17",
    "@types/papaparse": "5.5.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.5",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "pg": "8.20.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "darwin",
        "linux"
      ],
      "cpu": [
        "x64",
        "arm64"
      ],
      "libc": [
        "glibc"
      ]
    },
    "overrides": {
      "fast-xml-builder": ">=1.1.7",
      "axios": "^1.18.0",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "brace-expansion@>=3.0.0 <5.0.7": ">=5.0.7",
      "fast-uri": "^3.1.4",
      "sharp": ">=0.35.0"
    }
  }
}
